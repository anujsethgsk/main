        expr: "ifnull ( group_aggregate ( moving_average ( [New To Brand Patients] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) + { [Current Brand] = 'BENLYSTA' } + { [Mode Of Administration] = 'IV' } ) , 0 )"
        was_auto_generated: false
