    answer:
      name: Bio-Naive Family Share (R4W)
      tables:
      - id: Source Of Business
        name: Source Of Business
        fqn: 99515b8e-6cab-4177-850a-d1309b319ab3
      formulas:
      - id: formula_Naive Benlysta Share R4W
        name: Naive Benlysta Share R4W
        expr: "[formula_Naive Benlysta R4W] / ( [formula_Naive Benlysta R4W] + [formula_Naive Saphnelo R4W] + [formula_Naive Gazyva R4W] )"
        was_auto_generated: false
      - id: formula_Naive Gazyva Share R4W
        name: Naive Gazyva Share R4W
        expr: "[formula_Naive Gazyva R4W] / ( [formula_Naive Benlysta R4W] + [formula_Naive Saphnelo R4W] + [formula_Naive Gazyva R4W] )"
        was_auto_generated: false
      - id: formula_Naive Saphnelo Share R4W
        name: Naive Saphnelo Share R4W
        expr: "[formula_Naive Saphnelo R4W] / ( [formula_Naive Benlysta R4W] + [formula_Naive Saphnelo R4W] + [formula_Naive Gazyva R4W] )"
        was_auto_generated: false
      - id: formula_Market Share
        name: Market Share
        expr: "[New To Brand Patients] / [formula_NTB Market] "
        was_auto_generated: false
      - id: formula_NTB
        name: NTB
        expr: "group_aggregate ( sum ( [New To Brand Patients] ) , query_groups ( ) , query_filters ( ) )"
        was_auto_generated: false
      - id: formula_NTB Benlysta Share R4W
        name: NTB Benlysta Share R4W
        expr: "[formula_NTB Benlysta R4W] / ( [formula_NTB Benlysta R4W] + [formula_NTB Saphnelo R4W] + [formula_NTB Gazyva R4W] )"
        was_auto_generated: false
      - id: formula_NTB Gazyva Share R4W
        name: NTB Gazyva Share R4W
        expr: "[formula_NTB Gazyva R4W] / ( [formula_NTB Benlysta R4W] + [formula_NTB Saphnelo R4W] + [formula_NTB Gazyva R4W] )"
        was_auto_generated: false
      - id: formula_NTB Market
        name: NTB Market
        expr: "group_aggregate ( sum ( [New To Brand Patients] ) , query_groups ( ) , query_filters ( ) - { [Current Brand] } )"
        was_auto_generated: false
      - id: formula_NTB Saphnelo Share R4W
        name: NTB Saphnelo Share R4W
        expr: "[formula_NTB Saphnelo R4W] / ( [formula_NTB Benlysta R4W] + [formula_NTB Saphnelo R4W] + [formula_NTB Gazyva R4W] )"
        was_auto_generated: false
      - id: formula_NTB Benlysta R4W
        name: NTB Benlysta R4W
        expr: "group_aggregate ( moving_average ( [New To Brand Patients] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) + { [Current Brand] = 'BENLYSTA' } )"
        was_auto_generated: false
      - id: formula_NTB Gazyva R4W
        name: NTB Gazyva R4W
        expr: "group_aggregate ( moving_average ( [New To Brand Patients] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) + { [Current Brand] = 'GAZYVA' } + { [Specialty] != 'ONC' } )"
        was_auto_generated: false
      - id: formula_NTB Saphnelo R4W
        name: NTB Saphnelo R4W
        expr: "group_aggregate ( moving_average ( [New To Brand Patients] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) + { [Current Brand] = 'SAPHNELO' } )"
        was_auto_generated: false
      - id: formula_Naive Benlysta R4W
        name: Naive Benlysta R4W
        expr: "ifnull ( group_aggregate ( moving_average ( [Naive Patients Weekly] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) + { [Current Brand] = 'BENLYSTA' } ) , 0 )"
        was_auto_generated: false
      - id: formula_Naive Gazyva R4W
        name: Naive Gazyva R4W
        expr: "ifnull ( group_aggregate ( moving_average ( [Naive Patients Weekly] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) + { [Current Brand] = 'GAZYVA' } + { [Specialty] != 'ONC' } ) , 0 )"
        was_auto_generated: false
