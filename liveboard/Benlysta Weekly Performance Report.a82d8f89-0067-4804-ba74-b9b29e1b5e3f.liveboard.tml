      formulas:
      - id: formula_NTB Benlysta IV Share R4W
        name: NTB Benlysta IV Share R4W
        expr: "[formula_NTB Benlysta IV R4W] / ( [formula_NTB Benlysta R4W] + [formula_NTB Saphnelo R4W] + [formula_NTB Gazyva R4W] )"
        was_auto_generated: false
      - id: formula_NTB Benlysta SC Share R4W
        name: NTB Benlysta SC Share R4W
        expr: "[formula_NTB Benlysta SC R4W] / ( [formula_NTB Benlysta R4W] + [formula_NTB Saphnelo R4W] + [formula_NTB Gazyva R4W] )"
        was_auto_generated: false
      - id: formula_NTB Gazyva Share R4W
