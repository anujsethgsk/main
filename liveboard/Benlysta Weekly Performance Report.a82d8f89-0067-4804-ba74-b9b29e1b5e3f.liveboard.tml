  - id: Viz_39
    answer:
      name: Anuj - Market Share (R4W)
      description: Total Patients
      tables:
      - id: Source Of Business
        name: Source Of Business
        fqn: 99515b8e-6cab-4177-850a-d1309b319ab3
      formulas:
      - id: formula_Share
        name: Share
        expr: "( [formula_4 Week rolling average Total patients] / [formula_4 Week rolling Avg Total] )"
        was_auto_generated: false
      - id: formula_4 Week rolling average Total patients
        name: 4 Week rolling average Total patients
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago]  } )"
        was_auto_generated: false
      - id: formula_4 Week rolling Avg Total
        name: 4 Week rolling Avg Total
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 3 , 0 , [Week ID] ) , query_groups ( ) - { [Current Product Form] , [Mode Of Administration] , [Current Product Group] } , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } )"
        was_auto_generated: false
      search_query: "[Week ID] != '{null}' [Weeks Ago] = 1 [Week ID] [Week ID].weekly [Mode Of Administration] [Current Product Group] [formula_4 Week rolling average Total patients] [Week ID].weekly [formula_Share] [Market Desc].lupus [Current Product Group].benlysta [Current Product Group].GAZYVA [Current Product Group].saphnelo sort by [Week ID] [Week ID].weekly sort by [Mode Of Administration] descending sort by [Current Product Group]"
      answer_columns:
      - name: 4 Week rolling average Total patients
        format:
          category: NUMBER
          numberFormatConfig:
            unit: NONE
            decimals: 0.0
            negativeValueFormat: PREFIX_DASH
            toSeparateThousands: true
            removeTrailingZeroes: false
          isCategoryEditable: true
      - name: Current Product Group
        sort_info:
          category: ALPHA
      - name: Mode Of Administration
        sort_info:
          category: CUSTOM
      - name: Share
        format:
          category: NUMBER
          numberFormatConfig:
            unit: NONE
            decimals: 0.0
            negativeValueFormat: PREFIX_DASH
            toSeparateThousands: true
          isCategoryEditable: true
      - name: Week(Week ID)
        sort_info:
          category: DEFAULT
      table:
        table_columns:
        - column_id: 4 Week rolling average Total patients
          show_headline: false
        - column_id: Current Product Group
          show_headline: false
        - column_id: Mode Of Administration
