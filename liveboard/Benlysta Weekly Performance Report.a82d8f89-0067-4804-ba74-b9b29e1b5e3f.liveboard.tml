  - id: Viz_37
    answer:
      name: Data Week Ending
      tables:
      - id: Source Of Business
        name: Source Of Business
        fqn: 99515b8e-6cab-4177-850a-d1309b319ab3
      formulas:
      - id: formula_Benlysta WoW Growth
        name: Benlysta WoW Growth
        expr: "( [formula_Benlysta Total Patients R4W] - [formula_Benlysta Total Patients R4W-1] ) / [formula_Benlysta Total Patients R4W-1]"
        was_auto_generated: false
      - id: formula_Market 4 Week Avg
        name: Market 4 Week Avg
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 3 , 0 , [Week ID] ) , query_groups ( ) - { [Current Product Group] } , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } - { [Current Product Group] } )"
        was_auto_generated: false
      - id: formula_Market Prior 4 Weeks Avg
        name: Market Prior 4 Weeks Avg
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 7 , - 4 , [Week ID] ) , query_groups ( ) - { [Current Product Group] } , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } - { [Current Product Group] } )"
        was_auto_generated: false
      - id: formula_Market WoW Growth
        name: Market WoW Growth
        expr: "( [formula_Market Total Patients R4W] - [formula_Market Total Patients R4W-1] ) / [formula_Market Total Patients R4W-1] "
        was_auto_generated: false
      - id: formula_Market Total Patients R4W
        name: Market Total Patients R4W
        expr: "[formula_Benlysta Total Patients R4W] + [formula_Saphnelo Total Patients R4W] + [formula_Gazyva Total Patients R4W] "
        was_auto_generated: false
      - id: formula_Benlysta Total Patients R4W
        name: Benlysta Total Patients R4W
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } + { [Current Brand] = 'BENLYSTA' } )"
        was_auto_generated: false
      - id: formula_Gazyva Total Patients R4W
        name: Gazyva Total Patients R4W
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } + { [Current Brand] = 'GAZYVA' } + { [Specialty] != 'ONC' } )"
        was_auto_generated: false
      - id: formula_Market Total Patients R4W-1
        name: Market Total Patients R4W-1
        expr: "[formula_Benlysta Total Patients R4W-1] + [formula_Saphnelo Total Patients R4W-1] + [formula_Gazyva Total Patients R4W-1]"
        was_auto_generated: false
      - id: formula_Benlysta Total Patients R4W-1
        name: Benlysta Total Patients R4W-1
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 4 , - 1 , [Week ID] ) , query_groups ( ) , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } + { [Current Brand] = 'BENLYSTA' } )"
        was_auto_generated: false
      - id: formula_Gazyva Total Patients R4W-1
        name: Gazyva Total Patients R4W-1
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 4 , - 1 , [Week ID] ) , query_groups ( ) , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } + { [Current Brand] = 'GAZYVA' } + { [Specialty] != 'ONC' } )"
        was_auto_generated: false
      - id: formula_Saphnelo Total Patients R4W
        name: Saphnelo Total Patients R4W
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } + { [Current Brand]  = 'SAPHNELO' } )"
        was_auto_generated: false
      - id: formula_Saphnelo Total Patients R4W-1
        name: Saphnelo Total Patients R4W-1
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 4 , - 1 , [Week ID] ) , query_groups ( ) , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } + { [Current Brand] = 'SAPHNELO' } )"
        was_auto_generated: false
      - id: formula_Share
        name: Share
        expr: "( [formula_4 Week Avg] / [formula_Prior 4 Week Avg] )"
        was_auto_generated: false
      - id: formula_4 Week Avg
        name: 4 Week Avg
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } )"
        was_auto_generated: false
      - id: formula_Prior 4 Week Avg
        name: Prior 4 Week Avg
        expr: "group_aggregate ( moving_average ( [Total Patients Weekly] , 7 , - 4 , [Week ID] ) , query_groups ( ) , query_filters ( ) - { [Week ID] } + { [Week ID] != null } - { [Weeks Ago] } )"
        was_auto_generated: false
      - id: formula_max week F
        name: max week F
        expr: "if ( [max week P] = [max week P] ) then max ( [Week ID] ) else null"
        was_auto_generated: false
      search_query: "[Week ID] != '{null}' [Week ID].weekly [Market Desc] = 'lupus' sort by [Week ID] [Week ID].weekly descending [Weeks Ago] = 1"
