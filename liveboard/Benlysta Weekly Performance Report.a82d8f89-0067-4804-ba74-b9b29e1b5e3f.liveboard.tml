        expr: "ifnull ( group_aggregate ( moving_average ( [Naive Patients Weekly] , 3 , 0 , [Week ID] ) , query_groups ( ) , query_filters ( ) + { [Current Brand] = 'SAPHNELO' } ) , 0 )"
        was_auto_generated: false
