            decimals: 0.0
            negativeValueFormat: PREFIX_DASH
            toSeparateThousands: true
          isCategoryEditable: true
      table:
        table_columns:
        - column_id: Month(Month ID)
          show_headline: false
        - column_id: Pay Type
          show_headline: false
        - column_id: Total New To Brand Patients
