    note_tile:
      html_parsed_string: "<h2 class=\"theme-module__editor-h2\"><br></h2><p class=\"theme-module__editor-paragraph\" dir=\"ltr\"><span style=\"background-color: rgb(255, 255, 255); color: rgb(28, 35, 48); font-family: optimo-plain, &quot;helvetica neue&quot;, helvetica, arial, sans-serif; font-weight: 400; font-size: 14px; white-space: pre-wrap;\">This scorecard is meant to provide a quick summary for many of the common measures associated with patient counts. Select the market of interest in the top left.  Additional filters can be added by clicking on the \"pills\" above.</span></p><div class=\"pinboard-note-tile-module__noteTileBg editor-module__bgNode\" style=\"background-color: rgb(255, 255, 255);\"></div>"
  - id: Viz_39
    answer:
      name: This scorecard is meant to provide the cumulative YTD trends based on the metric selected above.
      tables:
      - id: Source of Business Special Time Period
        name: Source of Business Special Time Period
        fqn: 4bb1b923-3e6a-48c8-96fd-3a0cd07decbb
      formulas:
      - id: formula_Time Period
        name: Time Period
        expr: "if ( [Metric Selection] = 'Continue Patients' ) then concat ( 'Cumulative Continue PatientsYear to Date:  Time period is ' , max ( [Month Range] ) , ' /2025' ) else if ( [Metric Selection] = 'New To Brand Patients' ) then concat ( 'Cumulative New To Brand Patients Year to Date:  Time period is ' , max ( [Month Range] ) , ' /2025' ) else if ( [Metric Selection] = 'Switch Patients' ) then concat ( 'Cumulative Switch Patients Year to Date:  Time period is ' , max ( [Month Range] ) , ' /2025' ) else if ( [Metric Selection] = 'Total Patients' ) then concat ( 'Cumulative Total Patients Year to Date:  Time period is ' , max ( [Month Range] ) , ' /2025' ) else max ( [Diagnosis] ) "
        was_auto_generated: false
      search_query: "[formula_Time Period] [Is Ytd].'year to date'"
      answer_columns:
      - name: Time Period
      table:
        table_columns:
        - column_id: Time Period
          show_headline: false
        ordered_column_ids:
        - Time Period
        client_state: ""
        client_state_v2: "{\"tableVizPropVersion\": \"V1\",\"widthState\": [{\"columnId\": \"Time Period\",\"width\": 637.722412109375}]}"
      chart:
        type: KPI
        chart_columns:
        - column_id: Time Period
        axis_configs:
        - "y":
          - Time Period
        client_state: ""
        client_state_v2: "{\"version\": \"V4DOT2\",\"chartProperties\": {\"chartSpecific\": {\"pivotSummariesState\": {}}},\"columnProperties\": [{\"columnId\": \"Time Period\",\"columnProperty\": {}},{\"columnId\": \"Measure names\",\"columnProperty\": {}},{\"columnId\": \"Measure values\",\"columnProperty\": {}}],\"axisProperties\": [{\"id\": \"646b829b-b450-480a-b478-68672cf11890\",\"properties\": {\"axisType\": \"Y\",\"linkedColumns\": [\"Time Period\"],\"isOpposite\": false}},{\"id\": \"9f3cc454-4dd6-4978-9ac0-220386b47615\",\"properties\": {\"axisType\": \"X\"}}]}"
      display_mode: TABLE_MODE
      parameter_values:
      - key: Metric Selection
        value: Continue Patients
