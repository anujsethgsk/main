  - id: Viz_26
    answer:
      name: NTB Current Week - By Specialty
      tables:
      - id: Source Of Business
        name: Source Of Business
        fqn: 99515b8e-6cab-4177-850a-d1309b319ab3
      formulas:
      - id: formula_New To Brand Patient Growth
        name: New To Brand Patient Growth
        expr: "( sum ( [New To Brand Patients] ) - [formula_NTBP Prior Period]  ) / [formula_NTBP Prior Period]"
        was_auto_generated: false
      - id: formula_NTBP Prior Period
        name: NTBP Prior Period
        expr: "group_aggregate ( sum_if ( [Months Ago] = 2 , [New To Brand Patients] ) , query_groups ( ) - { [Month ID] } , query_filters ( ) - { [Months Ago] } )"
        was_auto_generated: false
      search_query: "[New To Brand Patients] [Specialty Code Group] sort by [Specialty Code Group] [Week ID] [Week ID].weekly [Week ID] != '{null}' [Weeks Ago] = 1"
      answer_columns:
      - name: Specialty Code Group
        sort_info:
          category: DEFAULT
      - name: Total New To Brand Patients
        format:
          category: NUMBER
          numberFormatConfig:
            unit: NONE
            decimals: 0.0
            negativeValueFormat: PREFIX_DASH
            toSeparateThousands: true
          isCategoryEditable: true
      - name: Week(Week ID)
      table:
        table_columns:
        - column_id: Specialty Code Group
          show_headline: false
        - column_id: Total New To Brand Patients
          show_headline: false
        - column_id: Week(Week ID)
          show_headline: false
        ordered_column_ids:
        - Specialty Code Group
        - Week(Week ID)
        - Total New To Brand Patients
        client_state: ""
        client_state_v2: "{\"tableVizPropVersion\": \"V1\",\"orderedColumnIds\": [\"Total New To Brand Patients\"],\"columnProperties\": [{\"columnId\": \"Total New To Brand Patients\",\"columnProperty\": {}}]}"
