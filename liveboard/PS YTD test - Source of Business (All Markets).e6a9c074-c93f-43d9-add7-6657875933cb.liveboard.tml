  - id: Viz_33
    answer:
      name: Current Month vs Last Year
      description: Growth
      tables:
      - id: Source Of Business
        name: Source Of Business
        fqn: 99515b8e-6cab-4177-850a-d1309b319ab3
      formulas:
      - id: formula_New To Brand Patient Growth
        name: New To Brand Patient Growth
        expr: "( sum ( [New To Brand Patients] ) - [formula_NTBP Prior Period]  ) / [formula_NTBP Prior Period]"
        was_auto_generated: false
      - id: formula_NTBP Prior Period
        name: NTBP Prior Period
        expr: "group_aggregate ( sum_if ( [Months Ago] = 13 , [New To Brand Patients] ) , query_groups ( ) - { [Month ID] } , query_filters ( ) - { [Months Ago] } ) "
        was_auto_generated: false
      search_query: "[formula_New To Brand Patient Growth] [Month ID] [Month ID].monthly [Months Ago] = 1 [Month ID] != '{null}' [Pay Type] sort by [Pay Type]"
      answer_columns:
      - name: Month(Month ID)
        custom_name: Monthly
      - name: New To Brand Patient Growth
        format:
          category: PERCENTAGE
          percentageFormatConfig:
            decimals: 1.0
          isCategoryEditable: true
      - name: Pay Type
        sort_info:
          category: DEFAULT
      table:
        table_columns:
        - column_id: Month(Month ID)
