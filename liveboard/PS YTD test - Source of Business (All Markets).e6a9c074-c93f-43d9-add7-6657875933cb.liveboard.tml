  - id: Viz_30
    answer:
      name: NTB Current Week - By Form
      tables:
      - id: Source Of Business
        name: Source Of Business
        fqn: 99515b8e-6cab-4177-850a-d1309b319ab3
      formulas:
      - id: formula_New To Brand Patient Growth
        name: New To Brand Patient Growth
        expr: "( sum ( [New To Brand Patients] ) - [formula_NTBP Prior Period]  ) / [formula_NTBP Prior Period]"
        was_auto_generated: false
      - id: formula_NTBP Prior Period
        name: NTBP Prior Period
        expr: "group_aggregate ( sum_if ( [Months Ago] = 2 , [New To Brand Patients] ) , query_groups ( ) - { [Month ID] } , query_filters ( ) - { [Months Ago] } )"
        was_auto_generated: false
      search_query: "[New To Brand Patients] [Current Product Form] [Week ID] [Week ID].weekly [Weeks Ago] = 1 [Week ID] != '{null}'"
      answer_columns:
      - name: Current Product Form
      - name: Total New To Brand Patients
        format:
          category: NUMBER
          numberFormatConfig:
            unit: NONE
            decimals: 0.0
            negativeValueFormat: PREFIX_DASH
            toSeparateThousands: true
          isCategoryEditable: true
      - name: Week(Week ID)
